const express = require('express');
const router = express.Router();
const multer = require('multer');
const path = require('path');
const fs = require('fs');
const sharp = require('sharp');
const {
  addProduct,
  getAllProducts,
  getProductById,
  getProductsByCategory,
  updateProduct,
  deleteProduct
} = require('../controllers/productController');

// Enhanced Multer storage configuration
const storage = multer.diskStorage({
  destination: (req, file, cb) => {
    cb(null, './uploads/temp/'); // Temporary storage for processing
  },
  filename: (req, file, cb) => {
    const uniqueSuffix = Date.now() + '-' + Math.round(Math.random() * 1E9);
    cb(null, 'product-' + uniqueSuffix + path.extname(file.originalname));
  },
});

// Enhanced file filter
const fileFilter = (req, file, cb) => {
  const allowedTypes = /jpeg|jpg|png|gif|webp/;
  const extname = allowedTypes.test(path.extname(file.originalname).toLowerCase());
  const mimetype = allowedTypes.test(file.mimetype);
  
  if (mimetype && extname) {
    cb(null, true);
  } else {
    cb(new Error('Only image files are allowed'));
  }
};

// Enhanced upload configuration with 50MB limit
const upload = multer({
  storage: storage,
  limits: {
    fileSize: 50 * 1024 * 1024, // 50MB limit
    files: 1
  },
  fileFilter: fileFilter
});

// Fast image processing middleware
const processImage = async (req, res, next) => {
  if (!req.file) {
    return next();
  }

  try {
    const tempFilePath = req.file.path;
    const filename = req.file.filename;
    const baseName = path.parse(filename).name;
    
    console.log(` Processing image: ${filename} (${Math.round(req.file.size / 1024)}KB)`);
    
    // Define output paths
    const compressedPath = `uploads/products/compressed/${baseName}.webp`;
    const thumbnailPath = `uploads/products/thumbnails/${baseName}_thumb.webp`;

    // Process images in parallel for speed
    await Promise.all([
      // Create compressed version (main image) - WebP format for better compression
      sharp(tempFilePath)
        .resize({ width: 1200, height: 1200, fit: 'inside', withoutEnlargement: true })
        .webp({ quality: 85 })
        .toFile(compressedPath),
      
      // Create thumbnail
      sharp(tempFilePath)
        .resize(300, 300, { fit: 'cover' })
        .webp({ quality: 80 })
        .toFile(thumbnailPath)
    ]);

    // Move original to organized location (keep for backup)
    const originalPath = `uploads/products/original/${filename}`;
    await fs.promises.rename(tempFilePath, originalPath);

